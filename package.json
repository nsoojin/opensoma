{
  "name": "opensoma-monorepo",
  "version": "0.1.3",
  "private": true,
  "description": "SWMaestro MyPage CLI & SDK monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bunx oxlint .",
    "lint:fix": "bunx oxlint . --fix",
    "format": "bunx oxfmt .",
    "format:check": "bunx oxfmt . --check",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "bun run --filter '*' test",
    "link": "bun link --cwd packages/opensoma",
    "unlink": "bun unlink --cwd packages/opensoma"
  },
  "devDependencies": {
    "webreel": "^0.1.4"
  }
}
