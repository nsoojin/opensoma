{
  "name": "@opensoma/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "kill": "lsof -ti:3100 | xargs kill -9 2>/dev/null",
    "dev": "bun run kill || true && next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.1.17",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.4",
    "next": "^16.2.3",
    "opensoma": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.13.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^0.15.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
